<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>\u7199&\u96c5 \ud83d\udc95 \u6200\u611b\u65e5\u8a18</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Noto+Sans+TC:wght@400;500;700&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
:root {
  --pink: #FF8FAB;
  --pink-light: #FFD6E0;
  --pink-pale: #FFF0F4;
  --blue: #74C0FC;
  --blue-light: #C5E8FF;
  --blue-pale: #EEF7FF;
  --purple: #C77DFF;
  --grad: linear-gradient(135deg, #FF8FAB 0%, #C77DFF 50%, #74C0FC 100%);
  --grad-soft: linear-gradient(135deg, #FFD6E0 0%, #E8D5FF 50%, #C5E8FF 100%);
  --white: #FFFFFF;
  --text: #4A3560;
  --text-light: #9B8AB4;
  --radius: 20px;
  --shadow: 0 8px 32px rgba(199,125,255,0.15);
  --shadow-card: 0 4px 20px rgba(255,143,171,0.2);
}

* { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }

body {
  font-family: 'Noto Sans TC', sans-serif;
  background: var(--grad-soft);
  min-height: 100vh;
  color: var(--text);
  overflow-x: hidden;
  padding-bottom: 80px;
}

/* ===== TOP HEADER ===== */
.app-header {
  background: var(--grad);
  padding: 16px 20px 12px;
  text-align: center;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 4px 20px rgba(199,125,255,0.3);
}
.app-header h1 {
  font-family: 'Nunito', sans-serif;
  font-size: 22px;
  font-weight: 900;
  color: white;
  letter-spacing: 2px;
  text-shadow: 0 2px 8px rgba(0,0,0,0.15);
}
.app-header p { font-size: 11px; color: rgba(255,255,255,0.85); margin-top: 2px; }

/* ===== BOTTOM NAV ===== */
.bottom-nav {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: white;
  display: flex;
  border-top: 1.5px solid var(--pink-light);
  z-index: 200;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -4px 20px rgba(199,125,255,0.15);
}
.nav-btn {
  flex: 1;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 8px 4px;
  border: none; background: none; cursor: pointer;
  font-size: 9px; color: var(--text-light);
  font-family: 'Noto Sans TC', sans-serif;
  font-weight: 600;
  transition: all 0.2s;
  gap: 3px;
}
.nav-btn .icon { font-size: 22px; line-height: 1; }
.nav-btn.active { color: var(--pink); }
.nav-btn.active .icon { transform: scale(1.1); }

/* ===== PAGES ===== */
.page { display: none; padding: 16px; animation: fadeIn 0.3s ease; }
.page.active { display: block; }
@keyframes fadeIn { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }

/* ===== CARDS ===== */
.card {
  background: white;
  border-radius: var(--radius);
  padding: 16px;
  margin-bottom: 14px;
  box-shadow: var(--shadow-card);
  border: 1.5px solid rgba(255,143,171,0.1);
}
.card-title {
  font-family: 'Nunito', sans-serif;
  font-size: 15px;
  font-weight: 800;
  color: var(--text);
  margin-bottom: 12px;
  display: flex; align-items: center; gap: 6px;
}

/* ===== PAGE 1: \u73ed\u8868 ===== */
.schedule-date-nav {
  display: flex; align-items: center; justify-content: space-between;
  background: var(--grad);
  border-radius: 16px;
  padding: 12px 16px;
  margin-bottom: 14px;
  color: white;
}
.schedule-date-nav button {
  background: rgba(255,255,255,0.3);
  border: none; color: white; font-size: 18px;
  width: 32px; height: 32px; border-radius: 50%; cursor: pointer;
}
.schedule-date-nav .date-label { font-family:'Nunito',sans-serif; font-weight:800; font-size:16px; }

.my-shift-card {
  background: linear-gradient(135deg, #FF8FAB, #FF6B9D);
  border-radius: 20px;
  padding: 20px;
  margin-bottom: 14px;
  color: white;
  text-align: center;
  box-shadow: 0 6px 24px rgba(255,107,157,0.4);
  position: relative;
  overflow: hidden;
}
.my-shift-card::before {
  content: '\u2728';
  position: absolute; top: -10px; right: -10px;
  font-size: 60px; opacity: 0.15;
}
.my-shift-card .label { font-size: 12px; opacity: 0.9; margin-bottom: 4px; }
.my-shift-card .shift-name { font-family:'Nunito',sans-serif; font-size: 28px; font-weight:900; }
.my-shift-card .shift-time { font-size: 18px; font-weight:700; margin-top: 4px; letter-spacing: 1px; }
.my-shift-card .shift-rest { font-size: 11px; opacity:0.85; margin-top: 6px; }

.handover-row {
  display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 14px;
}
.handover-card {
  border-radius: 16px;
  padding: 14px;
  text-align: center;
}
.handover-card.prev { background: linear-gradient(135deg, #C5E8FF, #74C0FC); }
.handover-card.next { background: linear-gradient(135deg, #FFD6E0, #FF8FAB); }
.handover-card .h-label { font-size: 10px; font-weight:700; color: rgba(74,53,96,0.7); margin-bottom: 4px; }
.handover-card .h-person { font-family:'Nunito',sans-serif; font-size: 16px; font-weight:800; color: var(--text); }
.handover-card .h-time { font-size: 11px; color: var(--text-light); margin-top: 2px; }

.full-schedule-title {
  font-family:'Nunito',sans-serif; font-size:14px; font-weight:800;
  color: var(--text); margin-bottom: 10px; display:flex; align-items:center; gap:6px;
}
.shift-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 10px 14px;
  border-radius: 12px;
  margin-bottom: 8px;
  background: var(--pink-pale);
  border: 1.5px solid rgba(255,143,171,0.15);
}
.shift-row.my-row {
  background: linear-gradient(90deg, rgba(255,143,171,0.15), rgba(199,125,255,0.1));
  border-color: var(--pink);
}
.shift-row .s-type { font-size: 12px; font-weight:700; color: var(--pink); }
.shift-row .s-person { font-size: 13px; font-weight:700; }
.shift-row .s-time { font-size: 11px; color: var(--text-light); }
.me-badge {
  background: var(--pink); color: white;
  font-size: 9px; padding: 2px 7px; border-radius: 10px; font-weight:700;
}

/* ===== PAGE 2: \u65e5\u66c6 ===== */
.calendar-nav {
  display: flex; align-items:center; justify-content:space-between;
  padding: 10px 0; margin-bottom: 10px;
}
.calendar-nav button {
  background: var(--pink-light); border:none; color: var(--text);
  font-size: 16px; width:36px; height:36px; border-radius:50%; cursor:pointer;
}
.calendar-nav .month-label {
  font-family:'Nunito',sans-serif; font-size:18px; font-weight:900; color: var(--text);
}
.weekday-row {
  display: grid; grid-template-columns: repeat(7,1fr);
  text-align: center; margin-bottom: 6px;
}
.weekday-row span {
  font-size: 10px; font-weight:700; color: var(--text-light); padding: 4px;
}
.weekday-row span:first-child { color: #FF6B6B; }
.weekday-row span:last-child { color: #74C0FC; }

.calendar-grid {
  display: grid; grid-template-columns: repeat(7,1fr); gap: 3px;
}
.cal-day {
  aspect-ratio: 1;
  border-radius: 10px;
  display: flex; flex-direction: column; align-items:center; justify-content:center;
  font-size: 13px; font-weight:600;
  cursor: pointer;
  position: relative;
  transition: all 0.2s;
  background: rgba(255,255,255,0.6);
  gap: 1px;
}
.cal-day:hover { transform: scale(1.05); }
.cal-day.today {
  background: var(--grad);
  color: white;
  box-shadow: 0 4px 12px rgba(199,125,255,0.4);
}
.cal-day.holiday { color: #FF4444; }
.cal-day.sunday { color: #FF6B6B; }
.cal-day.saturday { color: var(--blue); }
.cal-day.other-month { opacity: 0.3; }
.cal-day.has-note::after {
  content:''; position:absolute; bottom:3px; left:50%; transform:translateX(-50%);
  width:4px; height:4px; border-radius:50%; background: var(--pink);
}
.cal-day .day-emoji { font-size: 8px; line-height:1; }
.holiday-badge {
  background: rgba(255,68,68,0.1); border: 1px solid rgba(255,68,68,0.2);
  border-radius: 8px; padding: 3px 8px; font-size: 10px; color: #FF4444;
  font-weight:600; margin-bottom: 6px; display: inline-block;
}

/* Mood Modal */
.modal-overlay {
  display: none; position: fixed; inset:0;
  background: rgba(74,53,96,0.4); backdrop-filter: blur(4px);
  z-index: 500; align-items: flex-end; justify-content: center;
}
.modal-overlay.open { display: flex; }
.modal-sheet {
  background: white; border-radius: 24px 24px 0 0;
  padding: 20px 16px 32px;
  width: 100%; max-height: 80vh; overflow-y: auto;
  animation: slideUp 0.3s ease;
}
@keyframes slideUp { from{transform:translateY(100%)} to{transform:translateY(0)} }
.modal-handle { width:40px; height:4px; background: var(--pink-light); border-radius:2px; margin: 0 auto 16px; }
.modal-title { font-family:'Nunito',sans-serif; font-size:16px; font-weight:900; margin-bottom:14px; color:var(--text); }

/* Mood picker */
.mood-section-title { font-size:12px; font-weight:700; color:var(--text-light); margin:12px 0 8px; }
.mood-grid { display:grid; grid-template-columns: repeat(5,1fr); gap:8px; }
.mood-option {
  display:flex; flex-direction:column; align-items:center; gap:3px;
  padding: 8px 4px; border-radius:12px; cursor:pointer;
  border: 2px solid transparent; transition: all 0.2s;
  background: var(--pink-pale);
}
.mood-option.selected { border-color: var(--pink); background: var(--pink-light); }
.mood-option .m-emoji { font-size:22px; }
.mood-option .m-label { font-size:9px; font-weight:700; color: var(--text-light); }

.activity-grid { display:flex; flex-wrap:wrap; gap:6px; }
.act-tag {
  padding: 6px 12px; border-radius: 20px; font-size: 11px; font-weight:700;
  background: var(--blue-pale); color: var(--text); cursor:pointer;
  border: 2px solid transparent; transition: all 0.2s;
}
.act-tag.selected { border-color: var(--blue); background: var(--blue-light); }
.act-tag.his { background: var(--blue-pale); }
.act-tag.her { background: var(--pink-pale); }
.act-tag.his.selected { border-color: var(--blue); background: var(--blue-light); }
.act-tag.her.selected { border-color: var(--pink); background: var(--pink-light); }

.save-btn {
  width:100%; padding: 14px; border-radius: 16px;
  background: var(--grad); border: none; color: white;
  font-size: 14px; font-weight:700; cursor:pointer; margin-top: 16px;
  font-family:'Nunito',sans-serif;
}

/* ===== PAGE 3: \u884c\u7a0b\u8868 ===== */
.schedule-tabs { display:flex; gap:8px; margin-bottom:14px; }
.sched-tab {
  flex:1; padding:10px; text-align:center; border-radius:12px;
  font-size:12px; font-weight:700; cursor:pointer; border: 2px solid transparent;
  transition: all 0.2s;
  background: white; color: var(--text-light);
}
.sched-tab.active.his { background: var(--blue-light); border-color: var(--blue); color: var(--text); }
.sched-tab.active.her { background: var(--pink-light); border-color: var(--pink); color: var(--text); }

.trip-card {
  border-radius: 16px;
